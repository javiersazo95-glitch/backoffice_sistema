{
  "version": 2,
  "installCommand": "npm install --prefix backoffice/frontend",
  "buildCommand": "npm run build --prefix backoffice/frontend",
  "outputDirectory": "backoffice/frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
